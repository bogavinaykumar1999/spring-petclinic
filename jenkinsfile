pipeline {
    agent {label "java"}
    triggers {
        pollSCM("* * * * *")
    }
    stages {
        stage("git checkout") {
            steps {
                git url: "https://github.com/bogavinaykumar1999/spring-petclinic.git",
                    branch: "main"
            }

        }
        stage ("build and scan") {
            steps {
              withSonarQubeEnv("SONAR") {
              withCredentials([string(credentialsId: 'sonar-token', variable: 'TOKEN')]) {
              sh """mvn package sonar:sonar \\\
              -Dsonar.packagekey=bogavinaykumar1999_spring-petclinic \
              -Dsonar.oranisation=bogavinaykumar1999 \
              -Dsonar.host.url=https://sonarcloud.io/
              -Dsonar.login=$SONAR_TOKEN"""
              }

           }
 
       }

    }
}
    

