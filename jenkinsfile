pipeline {
    agent {label "java"}
    triggers {
        pollSCM("* * * * *")
    }
    stages {
        stage("git checkout") {
            steps {
                git url: "https://github.com/bogavinaykumar1999/spring-petclinic.git",
                    branch: "main"
            }
        }
        stage('Sonar Scan') {
            steps {
                withSonarQubeEnv('SONAR') {
                    withCredentials([string(credentialsId: 'sonar-token', variable: 'SONAR_TOKEN')]) {
                        sh '''
                        mvn clean verify sonar:sonar \
                        -Dsonar.projectKey=bogavinaykumar1999_spring-petclinic \
                        -Dsonar.organization=bogavinaykumar1999 \
                        -Dsonar.host.url=https://sonarcloud.io \
                        -Dsonar.login=$SONAR_TOKEN \
                        '''
                    }  
                }
            }
        }
        stage("artifactory") {
            steps{
               rtUpload (
                    serverId: "JFROG",
                    spec: '''{
                        "files": [
                        {
                        "pattern": "target/*.jar",
                        "target": "spcjava-spc"
                        }
                        ]
                    }'''
               )
                rtPublishBuildInfo(
                    serverId: "JFROG"
                )
            }

        }
    }
}
    
    

