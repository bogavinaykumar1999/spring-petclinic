pipeline {
    agent {label "java"}
    triggers {
        pollSCM("* * * * *")
    }
    stages {
        stage ("git checkout") {
            steps {
                git branch: "main",
                    url: "https://github.com/bogavinaykumar1999/spring-petclinic.git"
            }
        }
        stage ("build and scan") {
            steps {
                withSonarQubeEnv("SonarQube") {
                withCredentials([string(credentialsId:"sonar" ,variable:"SONAR_TOKEN")]) {
                sh """mvn package sonar:sonar \\\
                -Dsonar.packagekey=bogavinaykumar1999_spring-petclinic \
                -Dsonar.oranisation=bogavinaykumar1999 \
                -Dsonar.host.url=https://sonarcloud.io \
                -Dsonar.login=$SONAR_TOKEN"""
                }
                }
            }
        }
    }
}
    
    

